# ── Supabase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Rotate periodically — never expose publicly

# ── App URL (required — set to your deployment URL, e.g. https://remax-advance-crm.vercel.app) ──
NEXT_PUBLIC_APP_URL=https://YOUR_DOMAIN.vercel.app

# ── Google Calendar OAuth (required for GCal integration) ────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Authorized redirect URI to register in Google Cloud Console:
#   https://YOUR_DOMAIN.vercel.app/api/integrations/google/callback

# ── Meta Ads + Conversions API (optional — enables Meta Ads sync and CAPI) ───
META_ACCESS_TOKEN=EAA...           # System User token with ads_read + ads_management
META_AD_ACCOUNT_ID=123456789       # Ad Account ID (with or without act_ prefix)
META_PIXEL_ID=987654321            # Meta Pixel ID for Conversions API events

# ── OpenAI (required for Ava + PDF) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Ava WhatsApp agent (required for /api/ava) ────────────────────────────────
AVA_WEBHOOK_SECRET=your-random-secret   # Must match Railway env var

# ── Upstash Redis — distributed rate limiting (required in production) ────────
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
# Without these, rate limiter falls back to per-instance in-memory state.

# ── Sentry — error monitoring (optional) ─────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...   # Only needed for source map uploads in CI

# ── PostHog — analytics (optional) ───────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # Default, can omit
