{
  "framework": "nextjs",
  "functions": {
    "app/api/pdf/route.ts": {
      "memory": 1024,
      "maxDuration": 30
    },
    "app/api/ava/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/task-reminders/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/meta-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/lead-poll",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/tasas-sync",
      "schedule": "0 11,14,17,20,23,3 * * *"
    },
    {
      "path": "/api/cron/capi-dispatch",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/task-reminders",
      "schedule": "0 16 * * *"
    }
  ]
}
